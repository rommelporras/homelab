# Ansible
*.retry
ansible/*.log
ansible/inventory/*.bak

# Secrets (never commit real credentials)
**/secrets/
*.pem
*.key
*secret*
*password*

# Allow ExternalSecret CRDs (Vault path references, no real values)
!manifests/**/externalsecret.yaml
!manifests/**/externalsecret-*.yaml
!manifests/**/clustersecretstore.yaml
# Allow external-secrets Helm values (no credentials, just chart config)
!helm/external-secrets/
# Allow secret-related scripts (contain op:// refs, not actual values)
!scripts/seed-vault-from-1password.sh
!scripts/configure-vault.sh

# IDE
.vscode/
.idea/
.playwright-mcp/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Kubernetes
kubeconfig
*.kubeconfig

# Temporary
*.tmp
*.bak
*.backup

